#:kivy 2.1.0


<DynamixelCard>:
    orientation: 'vertical'
    spacing: dp(5)
    open_button: open_button
    close_button: close_button
    position_bar: position_bar
    close_label: close_label
    open_label: open_label
    position_entry: position_entry
    position_button: position_button
    velocity_entry: velocity_entry
    velocity_button: velocity_button

    SpaceLabel:
        font_style: "Caption"
        size_hint_y: 0.1
        halign: "center"
        text: str(root.dynamixel_widget.position) if root.dynamixel_widget else "--"

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.3

        SpaceLabel:
            id: close_label
            size_hint_x: 0.2
            text: '--'

        MDProgressBar:
            id: position_bar
            size_hint_x: 0.6
            size_hint_y: 0.1
            value: root.get_progress_bar_percent(root.dynamixel_widget.position) if root.dynamixel_widget is not None else 0
            color: app.theme_cls.primary_color

        SpaceLabel:
            id: open_label
            size_hint_x: 0.2
            halign: 'right'
            text: '--'

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.3
        spacing: dp(5)
        SpaceTextField:
            size_hint_x: 0.2
            size_x: dp(50)
            input_filter: 'int'
            id: position_entry
            text: '0'
        SpaceServiceButton:
            size_hint_x: 0.7
            id: position_button
            text: 'SET POSITION'
            ack_state:
                root.dynamixel_widget.ack_states['SET_POSITION'] \
                if root.dynamixel_widget is not None else AckStatus.READY
            callback:
                root.set_position \
                if root.dynamixel_widget is not None else lambda cb: None

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.3
        spacing: dp(5)
        SpaceTextField:
            size_hint_x: 0.2
            size_x: dp(50)
            input_filter: 'int'
            id: velocity_entry
            text: str(root.dynamixel_widget.velocity) if root.dynamixel_widget is not None else '0'
        SpaceServiceButton:
            size_hint_x: 0.7
            id: velocity_button
            text: 'SET VELOCITY'
            ack_state:
                root.dynamixel_widget.ack_states['SET_VELOCITY'] \
                if root.dynamixel_widget is not None else AckStatus.READY
            callback:
                root.set_velocity \
                if root.dynamixel_widget is not None else lambda cb: None

    SpaceServiceButton:
        id: open_button
        text: 'OPEN'
        size_hint_y: 0.3
        ack_state:
            root.dynamixel_widget.ack_states['OPEN'] \
            if root.dynamixel_widget is not None else AckStatus.READY
        callback:
            root.dynamixel_widget.open \
            if root.dynamixel_widget is not None else lambda cb: None

    SpaceServiceButton:
        id: close_button
        text: 'CLOSE'
        size_hint_y: 0.3
        ack_state:
            root.dynamixel_widget.ack_states['CLOSE'] \
            if root.dynamixel_widget is not None else AckStatus.READY
        callback:
            root.dynamixel_widget.close \
            if root.dynamixel_widget is not None else lambda cb: None
