#:kivy 2.1.0
#: import RelayWidget rocket_ground_station.components.device_widgets.relay_widget.RelayWidget
#: import DynamixelWidget rocket_ground_station.components.device_widgets.dynamixel_widget.DynamixelWidget
#: import ServoWidget rocket_ground_station.components.device_widgets.servo_widget.ServoWidget

<ValveVisual>:
    ack_states: self.device_widget.ack_states if self.device_widget is not None else {}
    position:
        root.device_widget.position if root.device_widget is not None \
        and (type(root.device_widget) in (DynamixelWidget, ServoWidget)) else -2
    open_pos:
        root.device_widget.open_pos if root.device_widget is not None \
        and (type(root.device_widget) in (DynamixelWidget, ServoWidget)) else -3
    closed_pos:
        root.device_widget.closed_pos if root.device_widget is not None \
        and (type(root.device_widget) in (DynamixelWidget, ServoWidget)) else -1
    is_synchronized:
        True if root.device_widget is None or type(root.device_widget) == RelayWidget else \
        root.device_widget.is_synchronized
    is_armed: False if root.device_widget is None else root.device_widget.is_device_armed

    size_hint: (.17, .25)
    pos_hint: {"center_x":root.icon_center_pos_hint[0], "center_y":root.icon_center_pos_hint[1]}
    img_size_hint_vertical: (.15, .31)
    img_size_hint_horizontal: (.22, .22)

    AsyncImage:
        size_hint: root.img_size_hint_vertical if root.icon_rotation == "vertical" else root.img_size_hint_horizontal
        pos_hint: {"center_x": .5, "center_y": .5}
        source: 'assets/hydraulics/valve_green_' + root.icon_rotation + '.png'
        allow_stretch: True
        keep_ratio: False
        opacity: 1 if root.device_widget is not None and root.state == "open" else 0
        id: img_open
    AsyncImage:
        size_hint: root.img_size_hint_vertical if root.icon_rotation == "vertical" else root.img_size_hint_horizontal
        pos_hint: {"center_x": .5, "center_y": .5}
        source: 'assets/hydraulics/valve_red_' + root.icon_rotation + '.png'
        allow_stretch: True
        keep_ratio: False
        opacity: 1 if root.device_widget is not None and root.state == "closed" else 0
        id: img_closed
    AsyncImage:
        size_hint: root.img_size_hint_vertical if root.icon_rotation == "vertical" else root.img_size_hint_horizontal
        pos_hint: {"center_x": .5, "center_y": .5}
        source: 'assets/hydraulics/valve_gray_' + root.icon_rotation + '.png'
        allow_stretch: True
        keep_ratio: False
        opacity:
            1 if root.device_widget is not None and \
            (root.state == "unknown" or root.combined_ack == AckStatus.DISABLED) else 0
        id: img_closed
    AsyncImage:
        size_hint: root.img_size_hint_vertical if root.icon_rotation == "vertical" else root.img_size_hint_horizontal
        pos_hint: {"center_x": .5, "center_y": .5}
        source: 'assets/hydraulics/valve_nack_' + root.icon_rotation + '.png'
        allow_stretch: True
        keep_ratio: False
        opacity: 1 if root.combined_ack == AckStatus.FAILED else 0
        id: img_closed
    AsyncImage:
        size_hint: root.img_size_hint_vertical if root.icon_rotation == "vertical" else root.img_size_hint_horizontal
        pos_hint: {"center_x": .5, "center_y": .5}
        source: 'assets/hydraulics/valve_pneumo_' + root.icon_rotation + '.png'
        allow_stretch: True
        keep_ratio: False
        opacity: 1 if root.device_widget is not None and type(root.device_widget) == RelayWidget else 0
        id: img_closed

    MDSpinner:
        id: spinner
        size_hint: 0.15, 0.15
        pos_hint: {'center_y': 0.5, 'center_x': 0.5}
        color: app.theme_cls.primary_color
        opacity: 1 if root.combined_ack == AckStatus.WAITING else 0

    MDRelativeLayout:
        size_hint: (.5,.25) if root.button_placement in {"top", "bottom"} else (.4, .5)
        pos_hint:
            {"x": .52, "center_y": .5} if root.button_placement == "right" else \
            {"x": .08, "center_y": .5} if root.button_placement == "left" else \
            {"center_x": .5, "top": 0.9} if root.button_placement == "top" else \
            {"center_x": .5, "top": 0.485}
        orientation: "vertical"
        MDLabel:
            size_hint: (1, .2)
            text: root.name
            halign: "center"
            font_size: min(root.size[0], root.size[1])/8
            pos_hint:
                {"center_x": .5, "center_y": 0.83} if root.button_placement == "top" else\
                {"center_x": .5, "center_y": -0.37} if root.button_placement == "bottom" else\
                {"center_x": .5, "center_y": 0.8}
        MDBoxLayout:
            orientation: "horizontal" if root.button_placement in {"top", "bottom"} else "vertical"
            size_hint: (0.85 if root.button_placement in {"top", "bottom"} else 1,1)
            pos_hint: {"center_x": .5, "center_y": 0.23} if root.button_placement in {"top", "bottom"} else {"center_x": .5, "center_y": 0.55}
            SpacePrimaryButton:
                md_bg_color:
                    app.theme_cls.primary_color if root.device_widget is not None \
                    and not (root.state == 'open' and root.combined_ack == AckStatus.SUCCESSFUL) \
                    else app.theme_cls.disabled_primary_color
                line_color: self.md_bg_color
                halign: "center"
                id: open_button
                text: "OPEN" if root.device_widget is None or root.is_synchronized else 'SYNC'
                size_hint: None, None
                height: 1 * self.parent.size[1] if root.button_placement in {"top", "bottom"} else 0.8 * self.parent.size[1]
                font_size: str(min(root.size[0], root.size[1])/12.6)  + "sp"
                size_hint_x: 0.16 if root.button_placement in {"top", "bottom"} else 0.6
                padding: self.parent.size[0]/30
                _min_width: 0
                _min_height: 0
                on_release:
                    (root.device_widget.open() if root.is_synchronized and root.is_armed else
                    root.device_widget.synchronize()) if root.device_widget is not None else None

            MDBoxLayout:
                size_hint: (None, None)
                size: (self.parent.size[0] * 0.04, self.parent.size[1] * 0.07)
            SpacePrimaryButton:
                md_bg_color:
                    app.theme_cls.primary_color if root.device_widget is not None \
                    and not (root.state == 'closed' and root.combined_ack == AckStatus.SUCCESSFUL) \
                    else app.theme_cls.disabled_primary_color
                line_color: self.md_bg_color
                halign: "center"
                id: close_button
                text: "CLOSE" if root.device_widget is None or root.is_synchronized else 'SYNC'
                size_hint: None, None
                height: 1 * self.parent.size[1] if root.button_placement in {"top", "bottom"} else 0.9 * self.parent.size[1]
                font_size: str(min(root.size[0], root.size[1])/12.6)  + "sp"
                size_hint_x: 0.16 if root.button_placement in {"top", "bottom"} else 0.6
                padding: self.parent.size[0]/30
                _min_width: 0
                _min_height: 0
                on_release:
                    (root.device_widget.close() if root.is_synchronized and root.is_armed else
                    root.device_widget.synchronize()) if root.device_widget is not None else None
