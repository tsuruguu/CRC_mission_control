<PressureGauge>:
    size_hint: (.10, .2)
    pos_hint: {"center_x":root.icon_center_pos_hint[0], "center_y":root.icon_center_pos_hint[1]}
    AsyncImage:
        size_hint: (.4*1.3, .5*1.3)
        pos_hint: {"center_x": .5, "center_y": .5}
        source: 'assets/hydraulics/pressure_gauge_'+root.placement+'.png'
        allow_stretch: True
    MDBoxLayout:
        pos_hint:
            {"center_x": .5, "top": 1.1}    if root.placement == "top" else \
            {"x": .65, "center_y": 0.4}     if root.placement == "right" else \
            {"right": .34, "center_y": 0.4} if root.placement == "left" else \
            {"center_x": 0.5, "top": 0.21}                       #bottom
        size_hint: (1, .27) if root.placement == "top" or root.placement == "bottom" else (1, .37)
        orientation: "vertical"
        MDLabel:
            size_hint: (1, .5)
            text: root.name
            halign: "center"
            font_size:root.size[0]/8
        MDLabel:
            color: app.theme_cls.primary_color
            size_hint: (1, .5)
            text:
                str(root.device_widget.rounded_value if root.round_to is None else
                round(root.device_widget.value, root.round_to)
                ) + ' ' + root.device_widget.units \
                if root.device_widget is not None else '--'
            halign: "center"
            font_size:root.size[0]/8
