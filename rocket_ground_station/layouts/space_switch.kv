#:kivy 2.1.0
#:import SpaceSwitch rocket_ground_station.components.space_switch.SpaceSwitch

<SpaceSwitch>:
    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    _track_color_normal: app.theme_cls.bg_light
    _track_color_active: app.theme_cls.primary_light
    thumb_color: app.theme_cls.primary_color
    thumb_color_down: app.theme_cls.primary_dark