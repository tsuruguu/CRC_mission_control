#        button_placement: "top"
#        icon_rotation: "horizontal"
    CardVisual:
        name: "tenso_visual"
        resize: True
        size_hint: (.15, .15)
        pos_hint: {"center_x": 0.085, "center_y": .9}

    CardVisual:
        name: "scheduler_visual"
        resize: True
        size_hint: (.15, .15)
        pos_hint: {"center_x": 0.085, "center_y": .73}

    ValveVisual:
        name: "UFV"
        icon_center_pos_hint: (755/3147, 1-983/1440)
        button_placement: "top"
        icon_rotation: "horizontal"
    ValveVisual:
        name: "LFV"
        icon_center_pos_hint: (755/3147, 1-1337/1440)
        button_placement: "top"
        icon_rotation: "horizontal"
    ValveVisual:
        name: "MFV"
        icon_center_pos_hint: (1398/3147, 1-897/1440)
        button_placement: "left"
        icon_rotation: "vertical"
    ValveVisual:
        name: "FFV"
        icon_center_pos_hint: (1260/3147, 1-486/1440)
        button_placement: "top"
        icon_rotation: "horizontal"
    ValveVisual:
        name: "VFV"
        icon_center_pos_hint: (1131/3147, 1-168/1440)
        button_placement: "top"
        icon_rotation: "horizontal"
    # ---- OX VALVES ----
    ValveVisual:
        name: "MOV"
        icon_center_pos_hint: (1749/3147, 1-897/1440)
        button_placement: "right"
        icon_rotation: "vertical"
    ValveVisual:
        name: "FOV"
        icon_center_pos_hint: (2095/3147, 1-752/1440)
        button_placement: "top"
        icon_rotation: "horizontal"
    ValveVisual:
        name: "UOV"
        icon_center_pos_hint: (2576/3147, 1-470/1440)
        button_placement: "right"
        icon_rotation: "vertical"
    ValveVisual:
        name: "LOV"
        icon_center_pos_hint: (2576/3147, 1-933/1440)
        button_placement: "right"
        icon_rotation: "vertical"
    ValveVisual:
        name: "VOV"
        icon_center_pos_hint: (1760/3147, 1-695/1440)
        button_placement: "top"
        icon_rotation: "horizontal"

    PistonVisual:
        name: "Piston"
        icon_center_pos_hint: (0.5, 1-474/1440)
        placement: "right"

    PressureGauge:
#        name: "P2"
        name: "ManifoldOx"
        icon_center_pos_hint: (1752/3147, 1 - 1110/1440)
        placement: "right"
        round_to: 2
    PressureGauge:
#        name: "P3"
        name: "ManifoldFuel"
        icon_center_pos_hint: (1395/3147, 1 - 1110/1440)
        placement: "left"
        round_to: 2
    PressureGauge:
#        name: "P4"
        name: "PVFuel"
        icon_center_pos_hint: (1693/3147, 1 - 252/1440)
        placement: "right"
        round_to: 2
    PressureGauge:
        name: "PVOx"
        icon_center_pos_hint: (1573/3147, 1 - 754/1440)
        placement: "bottom"
        round_to: 2
    PressureGauge:
        name: "Chamber"
        icon_center_pos_hint: (1718/3147, 1 - 1286/1440)
        placement: "right"
        round_to: 2
    PressureGauge:
        name: "Ext tank Ox"
